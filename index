<script>

/* AUTO DATE */

document.getElementById('quotationDate').valueAsDate = new Date();

/* INITIAL DATA */

const initialDataset = [

["20 mm", 18000, 3000, 28000],
["10 mm", 15600, 3000, 28000],
["6 mm", 16200, 3000, 28000],
["40 mm", 15000, 3000, 28000],
["Dust", 12000, 3000, 28000],
["Wet Mix", 15000, 3000, 28000],
["30 mm", 15600, 3000, 28000]

];

const tableBody = document.getElementById('tbody');

/* BUILD ROW */

function buildRowItem(
index,
matName,
baseValue,
royaltyValue,
transportValue
){

const rowEl = document.createElement('tr');

rowEl.innerHTML = `

<td class="index-cell">${index}</td>

<td>
<input type="text"
class="material-name"
value="${matName}">
</td>

<td>
<input type="number"
class="base-rate-input"
value="${baseValue}">
</td>

<td>
<input type="number"
class="royalty-input"
value="${royaltyValue}">
</td>

<td>
<input type="number"
class="transport-input"
value="${transportValue}">
</td>

<td class="subtotal-val">0</td>

<td class="gst-val">0</td>

<td class="final-total-col">0</td>

<td class="action-cell">

<button class="action-btn edit-btn"
onclick="toggleRowEdit(this)">
Edit
</button>

<button class="action-btn delete-btn"
onclick="this.closest('tr').remove(); reindexRows();">
Delete
</button>

</td>
`;

tableBody.appendChild(rowEl);

rowEl.querySelectorAll('input').forEach(inputField => {

inputField.addEventListener('input', () => {
runRowCalculations(rowEl);
});

});

runRowCalculations(rowEl);

}

/* EDIT TOGGLE */

function toggleRowEdit(button){

const row = button.closest('tr');

const isEditing = row.classList.toggle('editing');

if(isEditing){

button.innerText = "Lock";
button.style.background = "#b88120";

}else{

button.innerText = "Edit";
button.style.background = "#2b7a4b";

}

}

/* CALCULATIONS */

function runRowCalculations(row){

let basePrice =
parseFloat(
row.querySelector('.base-rate-input').value
) || 0;

let royaltyPrice =
parseFloat(
row.querySelector('.royalty-input').value
) || 0;

let transportPrice =
parseFloat(
row.querySelector('.transport-input').value
) || 0;

let subtotalAmount =
basePrice + royaltyPrice + transportPrice;

let gstAmount =
Math.round(subtotalAmount * 0.05);

let absoluteTotal =
subtotalAmount + gstAmount;

row.querySelector('.subtotal-val').innerText =
subtotalAmount.toLocaleString('en-IN');

row.querySelector('.gst-val').innerText =
gstAmount.toLocaleString('en-IN');

row.querySelector('.final-total-col').innerText =
absoluteTotal.toLocaleString('en-IN');

}

/* REINDEX */

function reindexRows(){

document.querySelectorAll('#tbody tr')
.forEach((row, index) => {

row.querySelector('.index-cell').innerText =
index + 1;

});

}

/* ADD ROW */

function addRow(){

const nextIdx =
tableBody.children.length + 1;

buildRowItem(
nextIdx,
"New Specification Sizes",
0,
3000,
28000
);

const lastRow = tableBody.lastElementChild;

const editBtn =
lastRow.querySelector('.edit-btn');

toggleRowEdit(editBtn);

}

/* PDF */

function downloadPDF(){

const targetElement =
document.getElementById('quotation');

const controlButtons =
document.querySelector('.buttons');

const actionHeaders =
document.querySelectorAll(
'.action-header, .action-cell'
);

controlButtons.style.display = 'none';

actionHeaders.forEach(item => {
item.style.setProperty(
'display',
'none',
'important'
);
});

const configuration = {

margin: 0.2,

filename:
'DPS_Stone_Crusher_Quotation.pdf',

image: {
type: 'jpeg',
quality: 0.98
},

html2canvas: {
scale: 2.5,
useCORS: true
},

jsPDF: {
unit: 'in',
format: 'a4',
orientation: 'portrait'
}

};

html2pdf()
.from(targetElement)
.set(configuration)
.save()
.then(() => {

controlButtons.style.display = 'flex';

actionHeaders.forEach(item => {
item.style.removeProperty('display');
});

});

}

/* INITIAL LOAD */

initialDataset.forEach((rowMeta, i) => {

buildRowItem(i + 1, ...rowMeta);

});

</script>

